working_dir: scratch/lc3_eqtltest
tools:
- smr
- coloc
- ecaviar
- fastenloc
input:
  gwas:
    file: locuscompare2pluefile/testgwas/preprocessed_mono_build37_170721_20161212.tsv.gz
    target_loci: 'ALL'
    trait: GCST004625_mono
    sample_size: 170721
    type: quant
    col_name_mapping:
      snp: rsid
      chrom: chr
      position: pos
      beta: beta
      effect_allele: alt
      other_allele: ref
      pvalue: pval
      se: se
      variant_id: variant_id
  qtl:
    qtl_type: 'eQTL'
    file: scratch/qsub_dir/Whole_Blood.v10.eqtl.tsv.gz
    qtl_preprocessed_dir: scratch/lc3_eqtltest/preprocessed/
    biological_context: Whole_Blood
    sample_size: 803
    type: quant
    col_name_mapping:
      snp: rs_id_dbSNP155_GRCh38p13
      chrom: chr
      position: pos
      beta: slope
      alt: alt
      ref: ref
      pvalue: pval_nominal
      se: slope_se
      phenotype_id: phenotype_id
      maf: maf
      variant_id: variant_id
  vcf: locuscompare2file/vcf_hg38
  genecode: locuscompare2pluefile/reference/gencode.v39.GRCh38.genes.gtf
  ld_block_loci_file: locuscompare2file/eur_hg38_ld_block.bed
  prediction_dir: /data1_gwas_dev19/coloc/biodata/colocalization/raw/prediction_model_covariance/gtex_v8_mashr
  twas_model_dir: /data1_gwas_dev19/coloc/biodata/colocalization/raw/twas_model
p-value_threshold:
  gwas: 5.0e-08
  qtl: 1.0e-05
population: EUR
